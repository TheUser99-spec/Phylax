---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import WhyPhylax from '../components/WhyPhylax.astro';
import HowItWorks from '../components/HowItWorks.astro';
import RealExample from '../components/RealExample.astro';
import PolicyCards from '../components/PolicyCards.astro';
import InstallSection from '../components/InstallSection.astro';
import SiteFooter from '../components/SiteFooter.astro';

const title = 'Phylax - OS-level Protection for AI Coding Agents';
const description = 'Phylax stops AI agents from reading secrets, deleting files, or touching anything outside your source code. 100% local, kernel-level Windows ACL enforcement.';
const image = '/og-card.png';
const homeStructuredData = JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      name: 'Phylax',
      url: 'https://phylax.pages.dev',
      description: description,
      sameAs: [
        'https://github.com/TheUser99-spec/Phylax',
        'https://x.com/Phylaxdev'
      ]
    },
    {
      '@type': 'WebSite',
      name: 'Phylax',
      url: 'https://phylax.pages.dev',
      description: description,
      potentialAction: {
        '@type': 'SearchAction',
        target: 'https://phylax.pages.dev/docs#{search_term_string}',
        'query-input': 'required name=search_term_string'
      }
    },
    {
      '@type': 'SoftwareApplication',
      name: 'Phylax',
      applicationCategory: 'SecurityApplication',
      applicationSubCategory: 'File Protection',
      operatingSystem: 'Windows 10, Windows 11',
      description: description,
      url: 'https://phylax.pages.dev',
      sameAs: [
        'https://github.com/TheUser99-spec/Phylax',
        'https://x.com/Phylaxdev'
      ],
      screenshot: 'https://phylax.pages.dev/og-card.png',
      featureList: [
        'Windows ACL enforcement with DENY ACEs and Mandatory Integrity Control',
        'Multi-agent detection (Claude Code, Cursor, OpenCode, Copilot, Windsurf, Aider)',
        'Three-layer anti-bypass protection',
        'SQLite audit logging with 100% local storage',
        'Real-time terminal dashboard at 60fps',
        'Priority-ordered permission buckets (deny > ask > full > delete > write > read)'
      ],
      offers: {
        '@type': 'Offer',
        price: '0',
        priceCurrency: 'USD'
      },
      author: {
        '@type': 'Organization',
        name: 'Phylax Contributors',
        sameAs: [
          'https://github.com/TheUser99-spec/Phylax',
          'https://x.com/Phylaxdev'
        ]
      }
    },
    {
      '@type': 'FAQPage',
      mainEntity: [
        {
          '@type': 'Question',
          name: 'How do I stop AI agents like Claude Code from reading my .env files?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Install Phylax and add .env to the [deny] bucket in phylax.toml. Phylax applies real Windows ACLs enforced by the kernel — the agent receives ACCESS_DENIED before reading a single byte.'
          }
        },
        {
          '@type': 'Question',
          name: 'Can AI coding agents bypass file permissions?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Phylax uses three layers of protection: DENY ACEs block access, WRITE_DAC prevents ACL modification, and Mandatory Integrity Control labels stop privilege bypass. Even icacls /remove:d is blocked at the kernel level.'
          }
        },
        {
          '@type': 'Question',
          name: 'What AI agents does Phylax protect against?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Phylax detects and blocks Claude Code, Cursor, OpenCode, GitHub Copilot CLI, Windsurf, Aider, Goose, Cline, and Gemini CLI automatically via process name, environment variables, and command-line inspection.'
          }
        },
        {
          '@type': 'Question',
          name: 'Does Phylax require an internet connection or cloud account?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'No. Phylax is 100% local — no accounts, no cloud, no telemetry. All audit logs stay on your machine in SQLite. Works fully offline.'
          }
        },
        {
          '@type': 'Question',
          name: 'Is Phylax free for commercial use?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Yes, Phylax is free and open-source under the Apache 2.0 license. Free for personal and commercial use. No paid tiers, no enterprise pricing.'
          }
        }
      ]
    }
  ]
});
---

<Base title={title} description={description} image={image} structuredData={homeStructuredData}>
  <main>
    <Hero />
    <WhyPhylax />
    <HowItWorks />
    <RealExample />
    <PolicyCards />
    <InstallSection />
    <SiteFooter />
  </main>
</Base>
