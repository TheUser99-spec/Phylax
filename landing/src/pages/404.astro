---
import Base from '../layouts/Base.astro';

const title = '404 - Page not found';
const description = 'The page you are looking for does not exist.';
---

<Base title={title} description={description}>
  <main>
    <nav class="site-nav" aria-label="Primary navigation">
      <a class="brand-mark" href="/" aria-label="Phylax home">
        <img src="/logo.jpg" alt="" class="brand-logo" width="28" height="28" />
        <span>Phylax</span>
      </a>
      <div class="nav-links">
        <a href="/">Home</a>
        <a href="/docs">Docs</a>
        <a href="/development-path">Development Path</a>
      </div>
    </nav>

    <section class="section" style="padding-top:160px;text-align:center">
      <div class="site-shell" style="max-width:500px">
        <p style="font-family:var(--mono);font-size:14px;color:var(--muted);margin-bottom:16px">404</p>
        <h1 style="font-family:var(--serif);font-size:clamp(32px,5vw,48px);line-height:1.1;margin:0 0 16px">This page is protected.</h1>
        <p style="font-size:16px;color:var(--muted);line-height:1.6;margin:0 0 32px">
          Or it doesn't exist. Either way, Phylax blocked it.
        </p>
        <a class="button button-primary" href="/">Back to safety</a>
      </div>
    </section>

    <footer class="closer">
      <div class="site-shell closer-grid">
        <div class="closer-links">
          <a href="https://github.com/TheUser99-spec/Phylax" target="_blank" rel="noreferrer">GitHub</a>
          <a href="/docs">Docs</a>
          <a href="/development-path">Development Path</a>
          <a href="/license">License</a>
        </div>
      </div>
    </footer>
  </main>
</Base>
