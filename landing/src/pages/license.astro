---
import Base from '../layouts/Base.astro';

const title = 'AgentGuard License - Apache 2.0';
const description = 'AgentGuard is open-source under the Apache 2.0 License. Comes with no warranty. See full terms.';
---

<Base title={title} description={description}>
  <main>
    <nav class="site-nav" aria-label="Primary navigation">
      <a class="brand-mark" href="/AgentGuard/" aria-label="AgentGuard home">
        <span>AgentGuard</span>
        <span class="brand-dot" aria-hidden="true"></span>
      </a>
      <div class="nav-links">
        <a href="/AgentGuard/">Home</a>
        <a href="/AgentGuard/docs">Docs</a>
        <a href="/AgentGuard/development-path">Development Path</a>
      </div>
    </nav>

    <section class="section" style="padding-top:100px">
      <div class="site-shell docs-content">
        <div class="docs-header">
          <p class="section-kicker">Legal</p>
          <h1 class="section-title" style="font-size:clamp(32px,4vw,44px)">License</h1>
          <p class="section-copy">Apache License, Version 2.0</p>
        </div>

        <div class="docs-note" style="margin-bottom:36px">
          <strong>Summary (this is not legal advice)</strong>
          <p>You can use, modify, and distribute AgentGuard freely - even commercially. You must include the license and copyright notice. The software comes with <strong>no warranty</strong> and the authors are <strong>not liable</strong> for any damages.</p>
        </div>

        <div class="docs-note docs-note--warn" style="margin-bottom:36px">
          <strong>Important</strong>
          <p>AgentGuard is a security tool, but it does <strong>not guarantee</strong> security, data protection, or prevention of unauthorized access. See the <a href="/AgentGuard/disclaimer" style="color:var(--blue);text-decoration:underline">full disclaimer</a> for details about liability.</p>
        </div>

        <div class="code-block" style="margin-bottom:32px">
          <div class="code-block-bar">
            <span class="code-block-lang">Apache License 2.0</span>
            <button class="code-block-copy" type="button" data-copy="Copyright 2025-2026 AgentGuard contributors">Copy notice</button>
          </div>
          <pre><code>Copyright 2025-2026 AgentGuard contributors

Licensed under the Apache License, Version 2.0 (the "License");
you may not use this file except in compliance with the License.
You may obtain a copy of the License at

    http://www.apache.org/licenses/LICENSE-2.0

Unless required by applicable law or agreed to in writing, software
distributed under the License is distributed on an "AS IS" BASIS,
WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.
See the License for the specific language governing permissions and
limitations under the License.</code></pre>
        </div>

