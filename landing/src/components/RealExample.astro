<section class="section" id="real-example">
  <div class="site-shell">
    <div class="section-header">
      <span class="section-number">03</span>
      <div>
        <p class="section-kicker">Real example</p>
        <h2 class="section-title">A real example.</h2>
        <p class="section-copy">
          This is what happens when an AI agent tries to access a protected file.
        </p>
      </div>
    </div>

    <div class="example-layout" data-reveal>
      <div class="example-console">
        <div class="console-bar">
          <span>agentguard audit tail</span>
          <span class="console-live">LIVE</span>
        </div>
        <div class="console-body">
          <div class="console-line"><span>08:16:08</span><span>AGENT</span><span>opencode.exe detected (env: OPENAICLIENT)</span></div>
          <div class="console-line"><span>08:16:08</span><span>TRY</span><span>opencode.exe read .env.local</span></div>
          <div class="console-line"><span>08:16:08</span><span>MATCH</span><span>deny bucket &rarr; .env.*</span></div>
          <div class="console-line"><span>08:16:08</span><span>DENY</span><span>DENY ACE applied &rarr; ACCESS_DENIED</span></div>
          <div class="console-line"><span>08:16:08</span><span>MIC</span><span>High Integrity label applied</span></div>
          <div class="console-line"><span>08:16:09</span><span>AUDIT</span><span>event stored in local SQLite</span></div>
        </div>
        <div class="console-caption">
          <span>Windows kernel rejected the operation before the agent touched the file</span>
        </div>
      </div>

      <p class="example-caption">
        AgentGuard applies <strong>three layers</strong> of Windows security: DENY ACEs block file access, WRITE_DAC protection prevents ACL modification, and Mandatory Integrity Control stops privilege bypass. The agent never sees a single byte.
      </p>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    gsap.fromTo(
      '#real-example [data-reveal]',
      { opacity: 0, y: 28 },
      { opacity: 1, y: 0, duration: 0.6, ease: 'power3.out', scrollTrigger: { trigger: '#real-example', start: 'top 74%' } }
    );
  }
</script>
