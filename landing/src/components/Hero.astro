      <span>AgentGuard</span>
      <span class="brand-dot" aria-hidden="true"></span>
    </a>
    <div class="nav-links">
      <a href="#top">Home</a>
      <a href="/AgentGuard/docs">Docs</a>
      <a href="/AgentGuard/development-path">Development Path</a>
    </div>
  </nav>

  <div class="site-shell hero-layout">
