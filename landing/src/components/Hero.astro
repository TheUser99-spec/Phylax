<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    gsap.fromTo(
      '[data-hero-reveal]',
      { opacity: 0, y: 32 },
      {
        opacity: 1,
        y: 0,
        duration: 0.8,
        ease: 'power3.out',
        stagger: 0.08,
        delay: 0.1,
      }
    );

    gsap.to('.hero-stage', {
      scrollTrigger: {
        trigger: '.hero-shell',
        start: 'top top',
        end: 'bottom top',
        scrub: true,
      },
      y: -24,
      transformOrigin: '50% 50%',
      ease: 'none',
    });
  }
</script>
